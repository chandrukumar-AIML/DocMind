# DOCUMIND AI - ROOT ENVIRONMENT TEMPLATE
# ADDED: Sanitized template. Copy values into .env locally or configure them in
# your deployment secret manager. Never commit real provider/API credentials.

ENVIRONMENT=production
APP_VERSION=1.0.0

# API
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false
CORS_ORIGINS=["https://your-frontend.example.com"]
MAX_UPLOAD_SIZE_MB=50
TMP_DIR=/tmp/documind

# Application auth
AUTH_ENABLED=true
ALLOW_SELF_REGISTRATION=false
FRONTEND_URL=https://your-frontend.vercel.app
JWT_SECRET_KEY=replace-with-a-random-64-plus-character-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
APP_API_KEYS=replace-with-app-api-key
DEFAULT_WORKSPACE_ID=default

# OpenAI / LLM
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_CHAT_MODEL=gpt-4o
LLM_PROVIDER=openai

# LangSmith
LANGCHAIN_TRACING_V2=false
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=documind-ai

# MLflow
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_EXPERIMENT_NAME=documind-ai

# Vector stores
CHROMA_PERSIST_DIR=/data/chroma
CHROMA_COLLECTION_NAME=documind_docs
CHROMA_AUTH_TOKEN=
CHROMA_AUTH_PROVIDER=
FAISS_INDEX_PATH=/data/faiss/index.bin

# RAG
RAG_CHUNK_SIZE_CHILD=256
RAG_CHUNK_SIZE_PARENT=1024
RAG_CHUNK_OVERLAP_CHILD=30
RAG_CHUNK_OVERLAP_PARENT=100
RAG_TOP_K_RETRIEVAL=20
RAG_TOP_K_RERANK=3

# OCR / document processing
OCR_CONFIDENCE_THRESHOLD=0.85
OCR_LANGUAGES=en
OCR_USE_GPU=false
WHISPER_MODEL=whisper-1
WHISPER_LANGUAGE=
ENABLE_SPEAKER_DIARIZATION=false
HUGGINGFACE_TOKEN=
HANDWRITING_CONFIDENCE_THRESHOLD=0.70
TROCR_MODEL_PATH=
MAX_AUDIO_SIZE_MB=100
SUPPORTED_AUDIO_FORMATS=mp3,mp4,wav,m4a,ogg,webm
SUPPORTED_DOC_FORMATS=docx,xlsx,pdf,pptx,txt,md

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=documind
POSTGRES_PASSWORD=replace-with-postgres-password
POSTGRES_DB=documind
DATABASE_URL=postgresql+asyncpg://documind:replace-with-postgres-password@postgres:5432/documind

# Redis / Celery
REDIS_URL=redis://redis:6379/2
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_WORKER_CONCURRENCY=2
CELERY_MAX_TASKS_PER_CHILD=50
CELERY_TASK_SOFT_TIME_LIMIT=600
CELERY_TASK_TIME_LIMIT=720
DEFAULT_QUEUE_TIER=default

# Neo4j
NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=replace-with-neo4j-password
NEO4J_DATABASE=neo4j

# Hugging Face
HF_USERNAME=

# ═══════════════════════════════════════════════════════════════
# DOCUMIND AI — ENVIRONMENT TEMPLATE (.env.example)
# Copy to .env and fill real values. NEVER commit .env!
# ═══════════════════════════════════════════════════════════════

# ── App Identity ───────────────────────────────────────────────
APP_NAME=DocuMind AI
APP_VERSION=2.0.0
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false
MAX_UPLOAD_SIZE_MB=50
TMP_DIR=/tmp/documind

# ── CORS (JSON array) ──────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://127.0.0.1:3000"]

# ── Database (DOCKER MODE) ─────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=documind
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_DB=documind
DATABASE_URL=postgresql+asyncpg://documind:changeme_in_production@postgres:5432/documind

# ── Redis/Celery (DOCKER MODE) ─────────────────────────────────
REDIS_URL=redis://redis:6379/2
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_WORKER_CONCURRENCY=2
CELERY_MAX_TASKS_PER_CHILD=50
CELERY_TASK_SOFT_TIME_LIMIT=600
CELERY_TASK_TIME_LIMIT=720
DEFAULT_QUEUE_TIER=default

# ── Neo4j (DOCKER MODE) ────────────────────────────────────────
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme_neo4j_password

# ── Vector Stores (DOCKER MODE) ────────────────────────────────
CHROMA_PERSIST_DIR=/data/chroma
CHROMA_COLLECTION_NAME=documind_docs
CHROMA_AUTH_TOKEN=
CHROMA_AUTH_PROVIDER=
FAISS_INDEX_PATH=/data/faiss/index.bin

# ── MLflow (DOCKER MODE) ───────────────────────────────────────
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_EXPERIMENT_NAME=documind-ai

# ── LLM Provider — Fallback chain: Ollama → Groq → OpenAI → Mock ──
LLM_PROVIDER=ollama
OLLAMA_MODEL=llama3.2:7b
OLLAMA_BASE_URL=http://localhost:11434

# Groq (free cloud LLM — fallback when Ollama is down)
# Get free key: https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI (paid, second cloud fallback)
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o

# ── Embeddings — Fallback chain: local sentence-transformers → Voyage AI → hash ──
EMBEDDING_PROVIDER=local
LOCAL_EMBEDDING_MODEL=all-mpnet-base-v2
EMBEDDING_DIMENSIONS=768

# Voyage AI (free 50M tokens — fallback when local ST fails)
# Get free key: https://dash.voyageai.com
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3-lite

# OpenAI embeddings key (only needed if EMBEDDING_PROVIDER=openai)
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_API_KEY=

# ── OCR — Fallback chain: PaddleOCR → Mistral OCR → pypdfium2 ──────
# Mistral OCR (free tier — fallback when PaddleOCR fails)
# Get free key: https://console.mistral.ai
MISTRAL_API_KEY=

# ── LangSmith (Optional) ───────────────────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=ls__your-langsmith-key
LANGCHAIN_PROJECT=documind-ai-dev

# ── OCR Configuration ──────────────────────────────────────────
OCR_CONFIDENCE_THRESHOLD=0.85
OCR_LANGUAGES=en,ch,hi,ar
OCR_USE_GPU=false

# ── RAG Configuration ──────────────────────────────────────────
RAG_CHUNK_SIZE_CHILD=256
RAG_CHUNK_SIZE_PARENT=1024
RAG_CHUNK_OVERLAP_CHILD=30
RAG_CHUNK_OVERLAP_PARENT=100
RAG_TOP_K_RETRIEVAL=20
RAG_TOP_K_RERANK=3

# ── Authentication ─────────────────────────────────────────────
JWT_SECRET_KEY=change-this-to-random-64-char-min-secret-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
# Dev only: set true in production
AUTH_ENABLED=false
DEFAULT_WORKSPACE_ID=default
# For app auth (NOT OpenAI key) — must be a JSON array (empty = no auth keys)
APP_API_KEYS=["your-app-api-key-here"]

# ── Audio/Handwriting (Optional) ───────────────────────────────
WHISPER_MODEL=whisper-1
WHISPER_LANGUAGE=en
ENABLE_SPEAKER_DIARIZATION=false
HUGGINGFACE_TOKEN=hf_your_token_here
HANDWRITING_CONFIDENCE_THRESHOLD=0.70
TROCR_MODEL_PATH=
MAX_AUDIO_SIZE_MB=100
SUPPORTED_AUDIO_FORMATS=mp3,mp4,wav,m4a,ogg,webm
SUPPORTED_DOC_FORMATS=docx,xlsx,pdf,pptx,txt,md

# ── HuggingFace (Optional) ─────────────────────────────────────
HF_USERNAME=your-huggingface-username
HF_TOKEN=your-huggingface-token

# ── SMTP / Email (Feature 9: Onboarding Invites) ─────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@documind.ai
APP_BASE_URL=http://localhost:3000

# ── DocuSign E-Signature (Feature 6) ─────────────────────────
DOCUSIGN_INTEGRATION_KEY=your-docusign-integration-key
DOCUSIGN_ACCOUNT_ID=your-docusign-account-id
DOCUSIGN_ACCESS_TOKEN=your-docusign-access-token
DOCUSIGN_BASE_URL=https://demo.docusign.net/restapi/v2.1

# ── Webhook Security (Feature 1) ─────────────────────────────
WEBHOOK_DEFAULT_SECRET=change-this-webhook-secret-32chars-min
WEBHOOK_MAX_RETRIES=3
WEBHOOK_DELIVERY_TIMEOUT=10

# ── Super Admin (Feature 8) ───────────────────────────────────
SUPERADMIN_USER_ID=superadmin
SUPERADMIN_EMAIL=superadmin@documind.ai

# ── Onboarding & Invite Tokens (Feature 9) ───────────────────
INVITE_TOKEN_EXPIRY_HOURS=72
INVITE_FROM_NAME=DocuMind AI
INVITE_BASE_URL=http://localhost:3000
SENDGRID_API_KEY=SG.your-sendgrid-key-here

# ── Compliance Checker (Feature 7) ───────────────────────────
COMPLIANCE_DEFAULT_REGULATIONS=GDPR,INDIAN_CONTRACT,GST

# ── Regional Language (Feature 10) ────────────────────────────
REGIONAL_LANGUAGES_ENABLED=true
REGIONAL_DETECT_SCRIPT=true

# ── Stripe Billing (USD / Global) ─────────────────────────────────────────
# Get from: https://dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
# Get from: Dashboard → Developers → Webhooks → Add endpoint
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
# Create Products + Prices at: Dashboard → Products
# Starter Plan ($29/mo):
STRIPE_PRICE_ID_STARTER=price_starter_placeholder
# Pro Plan ($79/mo):
STRIPE_PRICE_ID_PRO=price_pro_placeholder

# ── Razorpay Billing (INR / India) ────────────────────────────────────────
# Sign up: https://dashboard.razorpay.com
# Get keys: Dashboard → Settings → API Keys
RAZORPAY_KEY_ID=rzp_test_your-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
# Set webhook secret: Dashboard → Settings → Webhooks
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret
# Create Subscription Plans (monthly): Dashboard → Subscriptions → Plans
# Starter (₹2499/mo):
RAZORPAY_PLAN_ID_STARTER=plan_starter_placeholder
# Pro (₹6599/mo):
RAZORPAY_PLAN_ID_PRO=plan_pro_placeholder

# ── Frontend URL (for Stripe redirect after checkout) ─────────────────────
FRONTEND_URL=http://localhost:5173